{
  "name": "grocery-list-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build:client": "cd client && bun install && bun run build",
    "dev:all": "concurrently \"bun run dev\" \"cd client && bun run dev\"",
    "test": "bun test --preload ./src/test/preload.ts src/routes"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "@types/bun": "latest"
  }
}
